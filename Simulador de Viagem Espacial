        "import random\n",
        "\n",
        "def realizar_check():\n",
        "    # Simulando os dados de telemetria\n",
        "    dados = {\n",
        "        \"temp_int\": round(random.uniform(15, 30), 1),\n",
        "        \"integridade\": random.choice([0, 1, 1, 1]),\n",
        "        \"energia\": random.randint(80, 100),\n",
        "        \"pressao_psi\": random.randint(2400, 3300),\n",
        "        \"modulos_ok\": random.choice([True, True, False])\n",
        "    }\n",
        "\n",
        "    alertas = []\n",
        "\n",
        "    if dados[\"integridade\"] == 0: alertas.append(\"Falha na Integridade Estrutural\")\n",
        "    if not (18 <= dados[\"temp_int\"] <= 26): alertas.append(f\"Temp. Interna Fora de Faixa ({dados['temp_int']}C)\")\n",
        "    if dados[\"energia\"] < 85: alertas.append(f\"Energia Critica ({dados['energia']}%)\")\n",
        "    if not (2500 <= dados[\"pressao_psi\"] <= 3200): alertas.append(f\"Pressao dos Tanques Instavel ({dados['pressao_psi']} PSI)\")\n",
        "    if not dados[\"modulos_ok\"]: alertas.append(\"Falha em Modulos Criticos\")\n",
        "\n",
        "    print(\"\\n--- RELATORIO DE TELEMETRIA ---\")\n",
        "    print(f\"Temperatura Interna: {dados['temp_int']}C\")\n",
        "    print(f\"Integridade Estrutural: {'OK' if dados['integridade'] == 1 else 'FALHA'}\")\n",
        "    print(f\"Nivel de Energia: {dados['energia']}%\")\n",
        "    print(f\"Pressao dos Tanques: {dados['pressao_psi']} PSI\")\n",
        "    print(f\"Status dos Modulos: {'OPERACIONAL' if dados['modulos_ok'] else 'FALHA'}\")\n",
        "    print(\"-------------------------------\\n\")\n",
        "\n",
        "    if not alertas:\n",
        "        print(\"STATUS FINAL: >>> PRONTO PARA DECOLAR <<<\")\n",
        "    else:\n",
        "        print(\"STATUS FINAL: !!! DECOLAGEM ABORTADA !!!\")\n",
        "        print(\"Motivos:\", \", \".join(alertas))\n",
        "\n",
        "realizar_check()"
      ]
    }
  ]
